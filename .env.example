# Profile links — managed in Vercel (Project → Settings → Environment Variables).
# All VITE_* values are PUBLIC (embedded in the client bundle), so this is for
# configuration, not secrets. Leave any unset to use the defaults in src/config.ts.
#
# Local dev: copy this file to `.env` and edit, or set the same vars in Vercel.

VITE_GITHUB_URL=https://github.com/itamarkln-dev
VITE_GITHUB_REPOS_URL=https://github.com/itamarkln-dev?tab=repositories
VITE_LINKEDIN_URL=https://www.linkedin.com/in/itamar-klein-8b56971a1/
VITE_EMAIL=itamarkln.dev@gmail.com
