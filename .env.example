# Profile links / contact — set as Vercel env vars (Project → Settings →
# Environment Variables) for production, and in a local `.env` for development.
# All VITE_* values are PUBLIC (embedded in the client bundle) — config, not secrets.
# These are required (src/config.ts has no in-code fallbacks). Copy to `.env` and fill in.

VITE_GITHUB_URL=https://github.com/your-username
VITE_GITHUB_REPOS_URL=https://github.com/your-username?tab=repositories
VITE_LINKEDIN_URL=https://www.linkedin.com/in/your-handle/
VITE_EMAIL=you@example.com
